@using CatalogModel.Models.BrandModels;
@model IEnumerable<BrandModel>; 
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

            <div class="row">
            <div class="h1">List of Brands</div>
            </div>
            

            <div class="row mt-3 mb-3">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <a class="btn btn-primary" asp-controller="Brand" asp-action="Create" >Create New Brand</a>
            </div>
            </div>

            <div class="row">
                <table class="table table-primary">
                <thead>
                    <tr>
                        <th>
                            Brand Id
                        </th>
                        <th>
                            Brand Name
                        </th>
                        <th>
                            Edit
                        </th>
                        <th>
                            Delete
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count() == 0)
                    {
                <tr>
                    <td colspan="4"><div class="h1 text-center">No Brands are Available</div></td>

                </tr>
                    }
                    else
                    {
                    @foreach (var brand in Model)
                    {
                        <tr>
                            <td>@brand.Id</td>
                            <td>@brand.Name</td>
                            <td>
                                <a class="btn btn-primary" asp-action="Edit" asp-controller="Brand" asp-route-Id="@brand.Id">Edit</a>
                            </td>
                            <td>
                                    <a class="btn btn-danger" asp-action="Delete" asp-controller="Brand" asp-route-Id="@brand.Id">Delete</a> 
                            </td>
                        </tr>
                    }
                    }
                </tbody>
            </table>
            </div>
