@using CatalogModel.Models.ProductModel;
@model IEnumerable<ProductModel>;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    img{
        width:100px;
        height:100px;
    }
</style>

<div class="row">
    <div class="h1">List of Products</div>
</div>


<div class="row mt-3 mb-3">
    <div class="col-lg-3 col-md-4 col-sm-6">
        <a class="btn btn-primary" asp-controller="Product" asp-action="CreateProduct">Create New Product</a>
    </div>
</div>

<div class="row">
    <table class="table table-primary">
        <thead>
            <tr>
                @* <th>
                    Product Id
                </th> *@
                <th>
                    Product Name
                </th>
                <th>Product Description</th>
                <th>Brand Name</th>
                <th>Type Name</th>
                <th>Product Image</th>
                <th>Product Cost</th>
                <th>Product Total Cost</th>
                <th>
                    Edit
                </th>
                <th>
                    Delete
                </th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count() == 0)
            {
                <tr>
                    <td colspan="8"><div class="h1 text-center">No Products are Available</div></td>

                </tr>
            }
            else
            {
                @foreach (var product in Model)
                {
                    <tr>
                        @* <td>@product.Id</td> *@
                        <td>@product.ProductName</td>
                        <td>@product.ProductDescription</td>
                        <td>@product.BrandId</td>
                        <td>@product.TypeId</td>
                        <td>
                            <img src="~/Products/@product.ImageFilePath" alt="Product Image" />
                        </td>
                        <td>@product.ProductCost</td>
                        <td>@product.ProductTotalCost</td>
                        <td>
                            <a class="btn btn-primary" asp-action="EditProduct" asp-controller="Product" asp-route-Id="@product.Id">Edit</a>
                        </td>
                        <td>
                            <a class="btn btn-danger" asp-action="DeleteProduct" asp-controller="Product" asp-route-Id="@product.Id">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
